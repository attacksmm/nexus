[Unit]
Description=Nexus Orchestrator
After=network.target

[Service]
Type=simple
User=attack
WorkingDirectory=/home/attack/nexus
Environment="PATH=/home/attack/nexus/.venv/bin:/usr/bin"
EnvironmentFile=-/home/attack/nexus/.env
ExecStart=/home/attack/nexus/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
